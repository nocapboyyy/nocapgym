{
  "name": "@gym-app/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "^6.9.0",
    "fastify": "^5.4.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "vitest": "^3.2.3"
  }
}
